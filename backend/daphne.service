[Unit]
Description=Daphne ASGI server for AnimeCore WebSocket
After=network.target

[Service]
Type=simple
User=www-root
Group=www-root
WorkingDirectory=/var/www/www-root/data/www/anisphere.ru/backend
Environment="DJANGO_SETTINGS_MODULE=config.settings"
Environment="PATH=/var/www/www-root/data/www/anisphere.ru/venv/bin"
ExecStart=/var/www/www-root/data/www/anisphere.ru/venv/bin/daphne -b 127.0.0.1 -p 8002 config.asgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
